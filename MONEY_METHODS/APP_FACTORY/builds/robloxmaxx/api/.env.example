# RobloxMaxx Environment Variables
# Copy this to .env.local and fill in your values

# BYOK MODEL: No Anthropic API key needed on the server.
# Users bring their own API key in every request.
# ANTHROPIC_API_KEY is NOT required.

# Auth
JWT_SECRET=change-this-to-a-random-string-at-least-32-chars

# Stripe (for Pro subscription billing)
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Stripe Price IDs (create these in Stripe dashboard)
STRIPE_PRICE_PRO=price_xxxxx
