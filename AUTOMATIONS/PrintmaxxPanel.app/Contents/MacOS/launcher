#!/bin/bash
# PRINTMAXX Control Panel Launcher
# Checks if control_panel.py is already running on port 9999,
# starts it if not, then opens the browser.

PANEL_SCRIPT="/Users/macbookpro/Documents/p/PRINTMAXX_STARTER_KITttttt/AUTOMATIONS/control_panel.py"
PORT=9999
URL="http://localhost:${PORT}"

# Check if port 9999 is already in use
if lsof -i :${PORT} -sTCP:LISTEN -t >/dev/null 2>&1; then
    # Already running — just open browser
    open "${URL}"
    exit 0
fi

# Not running — start control panel in background
cd "$(dirname "${PANEL_SCRIPT}")"
nohup python3 "${PANEL_SCRIPT}" >/dev/null 2>&1 &

# Wait for the server to come up (max 10 seconds)
for i in $(seq 1 20); do
    if lsof -i :${PORT} -sTCP:LISTEN -t >/dev/null 2>&1; then
        break
    fi
    sleep 0.5
done

# Open in default browser
open "${URL}"
