    # SECTION 3: ENGAGEMENT (likes + follows)
    if phase_config["likes"] > 0 or phase_config["follows"] > 0:
        lines.append(f"## 3. ENGAGEMENT ({phase_config['likes']} likes, {phase_config['follows']} follows)")
        lines.append("")

