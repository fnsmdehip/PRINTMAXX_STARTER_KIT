            last_dt = datetime.fromisoformat(last)
            age = datetime.now() - last_dt
            status = "OK" if age < timedelta(hours=6) else "STALE" if age < timedelta(hours=24) else "DEAD"
        else:
            status = "NEVER_RUN"
        print(f"    {name:<25} {status}")
    print()


