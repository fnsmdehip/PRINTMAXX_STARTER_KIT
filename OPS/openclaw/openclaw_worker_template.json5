// PRINTMAXX worker template for official OpenClaw.
// Copy to ~/.openclaw/openclaw.json on the worker.
// Keep gateway loopback-only and access it remotely via SSH tunnel from control node.

{
  gateway: {
    bind: "loopback",
    port: 18789,
    auth: {
      mode: "token",
      token: "${OPENCLAW_GATEWAY_TOKEN}",
    },
  },

  agents: {
    defaults: {
      workspace: "~/.openclaw/workspace-printmaxx-worker",
      userTimezone: "America/New_York",
      model: {
        // Replace these with your currently available OpenRouter model IDs if needed.
        primary: "openrouter/moonshotai/kimi-k2-0905",
        fallbacks: [
          "openrouter/deepseek/deepseek-chat-v3.2",
          "openrouter/google/gemini-2.0-flash-001",
        ],
      },
      timeoutSeconds: 600,
      maxConcurrent: 2,
      thinkingDefault: "low",
      sandbox: {
        // Keep "off" unless you build and validate Docker sandbox images on worker.
        mode: "off",
      },
    },
  },

  tools: {
    allow: [
      "read",
      "write",
      "edit",
      "apply_patch",
      "exec",
      "process",
      "sessions_list",
      "sessions_history",
      "sessions_send",
      "sessions_spawn",
    ],
    deny: [
      "browser",
      "canvas",
      "nodes",
      "cron",
      "gateway",
    ],
  },

  env: {
    OPENROUTER_API_KEY: "${OPENROUTER_API_KEY}",
  },
}
