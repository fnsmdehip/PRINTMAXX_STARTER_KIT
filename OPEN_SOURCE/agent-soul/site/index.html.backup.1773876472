<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>sovrun - autonomous agent OS</title>
<meta name="description" content="cognitive and behavioral layer for autonomous AI agent systems. voice modeling, correction chains, soul drift scoring. stdlib python. zero deps.">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg: #0a0a0a;
  --bg-card: #111111;
  --bg-card-hover: #161616;
  --border: #1e1e1e;
  --border-accent: #2a2a2a;
  --text: #e0e0e0;
  --text-dim: #888888;
  --text-bright: #ffffff;
  --accent: #3b82f6;
  --accent-dim: #2563eb;
  --green: #22c55e;
  --red: #666666;
  --yellow: #eab308;
  --mono: 'SF Mono', 'Cascadia Code', 'Fira Code', 'JetBrains Mono', 'Consolas', monospace;
  --sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

html { scroll-behavior: smooth; }

body {
  font-family: var(--sans);
  background: var(--bg);
  color: var(--text);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

a { color: var(--accent); text-decoration: none; }
a:hover { text-decoration: underline; }

/* layout */
.container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
section { padding: 80px 0; }
section + section { border-top: 1px solid var(--border); }

/* nav */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: rgba(10,10,10,0.85); backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
  padding: 12px 0;
}
nav .container { display: flex; justify-content: space-between; align-items: center; }
nav .logo { font-family: var(--mono); font-size: 18px; font-weight: 700; color: var(--text-bright); letter-spacing: -0.5px; }
nav .links { display: flex; gap: 24px; font-size: 14px; }
nav .links a { color: var(--text-dim); }
nav .links a:hover { color: var(--text-bright); text-decoration: none; }

/* hero */
.hero { padding: 160px 0 100px; text-align: center; }
.hero h1 {
  font-family: var(--mono);
  font-size: clamp(48px, 8vw, 80px);
  font-weight: 800;
  color: var(--text-bright);
  letter-spacing: -3px;
  line-height: 1;
  margin-bottom: 16px;
}
.hero .tagline {
  font-family: var(--mono);
  font-size: clamp(14px, 2vw, 18px);
  color: var(--text-dim);
  margin-bottom: 24px;
  letter-spacing: -0.3px;
}
.hero .oneliner {
  font-size: 18px;
  color: var(--text);
  max-width: 640px;
  margin: 0 auto 40px;
  line-height: 1.5;
}
.hero-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; align-items: center; }
.btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 12px 24px;
  border-radius: 6px;
  font-family: var(--mono);
  font-size: 14px;
  font-weight: 500;
  border: none;
  cursor: pointer;
  transition: all 0.15s;
}
.btn-primary { background: var(--accent); color: white; }
.btn-primary:hover { background: var(--accent-dim); text-decoration: none; }
.btn-secondary { background: transparent; color: var(--text); border: 1px solid var(--border-accent); }
.btn-secondary:hover { border-color: var(--text-dim); text-decoration: none; }
.badge {
  display: inline-flex; align-items: center;
  margin-top: 20px;
}
.badge img { height: 20px; }

/* section headers */
.section-label {
  font-family: var(--mono);
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--accent);
  margin-bottom: 12px;
}
.section-title {
  font-size: clamp(24px, 4vw, 36px);
  font-weight: 700;
  color: var(--text-bright);
  margin-bottom: 16px;
  letter-spacing: -1px;
}
.section-desc {
  font-size: 16px;
  color: var(--text-dim);
  max-width: 640px;
  line-height: 1.6;
}

/* problem */
.problem-text {
  font-size: 18px;
  line-height: 1.7;
  max-width: 720px;
}
.problem-text strong { color: var(--text-bright); }

/* module grid */
.layer-group { margin-bottom: 48px; }
.layer-group:last-child { margin-bottom: 0; }
.layer-label {
  font-family: var(--mono);
  font-size: 13px;
  color: var(--accent);
  margin-bottom: 16px;
  padding-bottom: 8px;
  border-bottom: 1px solid var(--border);
  text-transform: uppercase;
  letter-spacing: 1.5px;
}
.module-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 12px;
}
.module-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 20px;
  transition: border-color 0.15s, background 0.15s;
}
.module-card:hover { border-color: var(--border-accent); background: var(--bg-card-hover); }
.module-name {
  font-family: var(--mono);
  font-size: 14px;
  font-weight: 600;
  color: var(--text-bright);
  margin-bottom: 6px;
}
.module-desc {
  font-size: 13px;
  color: var(--text-dim);
  line-height: 1.5;
  margin-bottom: 8px;
}
.module-key {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--accent);
  background: rgba(59,130,246,0.08);
  display: inline-block;
  padding: 2px 8px;
  border-radius: 4px;
}

/* comparison table */
.table-wrapper {
  overflow-x: auto;
  margin: 32px 0 0;
  border: 1px solid var(--border);
  border-radius: 8px;
}
.comparison-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
  min-width: 900px;
}
.comparison-table th {
  font-family: var(--mono);
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  padding: 14px 12px;
  text-align: left;
  background: var(--bg-card);
  border-bottom: 1px solid var(--border);
  color: var(--text-dim);
  position: sticky;
  top: 0;
  white-space: nowrap;
}
.comparison-table th:first-child { color: var(--text); min-width: 180px; }
.comparison-table th.highlight { color: var(--accent); }
.comparison-table td {
  padding: 10px 12px;
  border-bottom: 1px solid var(--border);
  color: var(--text-dim);
  vertical-align: top;
}
.comparison-table tr:last-child td { border-bottom: none; }
.comparison-table td:first-child {
  font-family: var(--mono);
  font-size: 12px;
  color: var(--text);
  white-space: nowrap;
}
.comparison-table .yes { color: var(--green); }
.comparison-table .no { color: var(--red); }
.comparison-table .partial { color: var(--yellow); }
.comparison-table tbody tr:hover { background: var(--bg-card); }

/* quick start */
.quickstart-block {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 8px;
  overflow: hidden;
  margin-top: 32px;
}
.quickstart-header {
  font-family: var(--mono);
  font-size: 12px;
  color: var(--text-dim);
  padding: 12px 20px;
  background: rgba(255,255,255,0.02);
  border-bottom: 1px solid var(--border);
}
.quickstart-block pre {
  padding: 20px;
  overflow-x: auto;
  font-family: var(--mono);
  font-size: 13px;
  line-height: 1.8;
  color: var(--text);
}
.quickstart-block .comment { color: var(--text-dim); }
.quickstart-block .cmd { color: var(--green); }

/* architecture */
.arch-diagram {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 32px;
  margin-top: 32px;
  overflow-x: auto;
}
.arch-diagram pre {
  font-family: var(--mono);
  font-size: 13px;
  line-height: 1.6;
  color: var(--text);
  text-align: center;
}
.arch-diagram .layer-cognitive { color: var(--accent); }
.arch-diagram .layer-orch { color: var(--green); }
.arch-diagram .layer-memory { color: var(--yellow); }
.arch-diagram .layer-infra { color: #a78bfa; }

/* production numbers */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 16px;
  margin-top: 32px;
}
.stat-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 24px;
  text-align: center;
}
.stat-number {
  font-family: var(--mono);
  font-size: 36px;
  font-weight: 700;
  color: var(--text-bright);
  letter-spacing: -2px;
}
.stat-label {
  font-size: 13px;
  color: var(--text-dim);
  margin-top: 4px;
}
.stat-note {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--text-dim);
  margin-top: 24px;
  text-align: center;
  opacity: 0.7;
}

/* footer */
footer {
  border-top: 1px solid var(--border);
  padding: 40px 0;
  text-align: center;
}
footer .footer-links {
  display: flex; gap: 24px; justify-content: center;
  font-family: var(--mono);
  font-size: 13px;
  margin-bottom: 16px;
}
footer .footer-links a { color: var(--text-dim); }
footer .footer-links a:hover { color: var(--text-bright); }
footer .footer-note {
  font-family: var(--mono);
  font-size: 12px;
  color: var(--text-dim);
  opacity: 0.5;
}

/* mobile */
@media (max-width: 768px) {
  section { padding: 60px 0; }
  .hero { padding: 120px 0 60px; }
  nav .links { gap: 16px; font-size: 13px; }
  .module-grid { grid-template-columns: 1fr; }
  .stats-grid { grid-template-columns: repeat(2, 1fr); }
  .hero-actions { flex-direction: column; align-items: center; }
}
@media (max-width: 480px) {
  nav .links { display: none; }
  .stats-grid { grid-template-columns: 1fr; }
}
</style>
</head>
<body>

<!-- nav -->
<nav>
  <div class="container">
    <a href="#" class="logo">sovrun</a>
    <div class="links">
      <a href="#modules">modules</a>
      <a href="#comparison">comparison</a>
      <a href="#quickstart">quickstart</a>
      <a href="https://github.com/fnsmdehip/sovrun">github</a>
    </div>
  </div>
</nav>

<!-- hero -->
<section class="hero">
  <div class="container">
    <h1>sovrun</h1>
    <p class="tagline">autonomous agent OS. stdlib python. zero deps.</p>
    <p class="oneliner">the cognitive and behavioral layer your AI agents are missing. voice modeling, correction chain learning, soul drift scoring, bias filtering. 15 modules extracted from a production autonomous system.</p>
    <div class="hero-actions">
      <a href="https://github.com/fnsmdehip/sovrun" class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        git clone
      </a>
      <a href="#quickstart" class="btn btn-secondary">pip install sovrun</a>
    </div>
    <div class="badge">
      <a href="https://github.com/fnsmdehip/sovrun"><img src="https://img.shields.io/github/stars/fnsmdehip/sovrun?style=flat&color=3b82f6&labelColor=1a1a1a" alt="GitHub stars"></a>
    </div>
  </div>
</section>

<!-- problem -->
<section id="problem">
  <div class="container">
    <p class="section-label">the problem</p>
    <div class="problem-text">
      <p>your AI agents run on default LLM knowledge and produce generic output. you correct them. <strong>they don't learn from the corrections.</strong> you correct them again. same mistakes. you've told your AI the same thing 50 times across different sessions and it still defaults to the behavior you hate.</p>
      <br>
      <p>nobody checks if agent output matches your actual voice. nobody scores whether agents are drifting from their directives. nobody closes the loop between "agent decided X" and "X actually happened." crash at step 14 of 16 and you lose all the work from steps 1 through 13.</p>
      <br>
      <p>sovrun solves each of these with a dedicated module. no framework lock-in, no dependency chain, no vendor SDK. just Python stdlib.</p>
    </div>
  </div>
</section>

<!-- modules -->
<section id="modules">
  <div class="container">
    <p class="section-label">what's in the box</p>
    <h2 class="section-title">15 modules. 4 layers.</h2>
    <p class="section-desc">wire them into whatever you're building. each module works standalone or together.</p>

    <div style="margin-top: 48px;">

      <!-- cognitive layer -->
      <div class="layer-group">
        <div class="layer-label">cognitive</div>
        <div class="module-grid">
          <div class="module-card">
            <div class="module-name">voice_extractor</div>
            <div class="module-desc">reads your prompt history, extracts your vocabulary, tone, banned words. outputs a voice model you inject into any agent prompt.</div>
            <span class="module-key">your prompts -> voice model -> agent injection</span>
          </div>
          <div class="module-card">
            <div class="module-name">cognitive_engine</div>
            <div class="module-desc">identifies correction chains in your history. builds meta-rules that would have prevented each correction sequence.</div>
            <span class="module-key">168 chains, 6.9 avg corrections per chain</span>
          </div>
          <div class="module-card">
            <div class="module-name">pattern_miner</div>
            <div class="module-desc">finds correction markers, escalation triggers, satisfaction signals. mines transferable rules from what pisses you off and what works.</div>
            <span class="module-key">correction + satisfaction + escalation signals</span>
          </div>
          <div class="module-card">
            <div class="module-name">user_sim_refiner</div>
            <div class="module-desc">simulates YOUR critique on any project. takes your cognitive architecture and applies your thinking when you're not in the room.</div>
            <span class="module-key">autonomous critique using your patterns</span>
          </div>
          <div class="module-card">
            <div class="module-name">self_audit</div>
            <div class="module-desc">checks for AI slop in your config files, context bloat wasting tokens, orphan scripts, missing protocols. the system that audits the system.</div>
            <span class="module-key">slop detection + context bloat + orphan scan</span>
          </div>
          <div class="module-card">
            <div class="module-name">bias-null protocol</div>
            <div class="module-desc">5-point pre-output filter. catches legacy smuggling, preemptive appeasement, popular-default traps, training-bias contamination.</div>
            <span class="module-key">template: run before every major output</span>
          </div>
        </div>
      </div>

      <!-- orchestration layer -->
      <div class="layer-group">
        <div class="layer-label">orchestration</div>
        <div class="module-grid">
          <div class="module-card">
            <div class="module-name">handoff</div>
            <div class="module-desc">typed agent-to-agent delegation with context transfer. agent A invokes agent B mid-task, passes state, receives result, continues.</div>
            <span class="module-key">scoped guardrails per handoff</span>
          </div>
          <div class="module-card">
            <div class="module-name">orchestration</div>
            <div class="module-desc">SequentialAgent, ParallelAgent, LoopAgent primitives. compose agents into DAGs. non-dependent phases run in parallel automatically.</div>
            <span class="module-key">DAG execution with typed state</span>
          </div>
          <div class="module-card">
            <div class="module-name">loop_closer</div>
            <div class="module-desc">closes 4 loops: decision execution, feedback tracking, pipeline advancement, soul drift scoring. scores every output 0-10 against SOUL.md.</div>
            <span class="module-key">alerts when drift drops below 6/10</span>
          </div>
          <div class="module-card">
            <div class="module-name">decision_engine</div>
            <div class="module-desc">closed-loop autonomous decisions. scan, score, act, log. CSV audit trail for every decision with full reasoning chain.</div>
            <span class="module-key">rule-based + LLM-delegated judgment</span>
          </div>
        </div>
      </div>

      <!-- memory layer -->
      <div class="layer-group">
        <div class="layer-label">memory</div>
        <div class="module-grid">
          <div class="module-card">
            <div class="module-name">procedural_memory</div>
            <div class="module-desc">auto-generates skill docs from successful agent runs. FTS5-indexed. before each run, queries for relevant past solutions.</div>
            <span class="module-key">agents remember what worked</span>
          </div>
          <div class="module-card">
            <div class="module-name">conversation_logger</div>
            <div class="module-desc">extracts messages from Claude session transcripts into searchable JSONL. incremental processing, keyword search, statistics.</div>
            <span class="module-key">search your entire prompt history</span>
          </div>
          <div class="module-card">
            <div class="module-name">session_briefing</div>
            <div class="module-desc">"what happened since last session" from git diffs, state files, task trackers. no LLM calls. pure file reading. under 30 seconds.</div>
            <span class="module-key">context continuity across sessions</span>
          </div>
        </div>
      </div>

      <!-- infrastructure layer -->
      <div class="layer-group">
        <div class="layer-label">infrastructure</div>
        <div class="module-grid">
          <div class="module-card">
            <div class="module-name">resilience</div>
            <div class="module-desc">retry with exponential backoff + jitter, file locking (fcntl), circuit breaker state machine, input sanitization, loop detection.</div>
            <span class="module-key">CLOSED -> OPEN -> HALF_OPEN -> CLOSED</span>
          </div>
          <div class="module-card">
            <div class="module-name">durable</div>
            <div class="module-desc">deterministic replay on crash. each step logged atomically. crash at step 14 replays from 14, not from 1. zero wasted API calls.</div>
            <span class="module-key">step-level checkpoint + replay</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- comparison -->
<section id="comparison">
  <div class="container">
    <p class="section-label">honest comparison</p>
    <h2 class="section-title">sovrun vs everything else</h2>
    <p class="section-desc">checkmarks where we actually deliver. X where we don't. no marketing spin.</p>

    <div class="table-wrapper">
      <table class="comparison-table">
        <thead>
          <tr>
            <th>feature</th>
            <th class="highlight">sovrun</th>
            <th>LangGraph</th>
            <th>CrewAI</th>
            <th>AutoGen</th>
            <th>Google ADK</th>
            <th>Hermes</th>
            <th>n8n</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>voice modeling (learns your style)</td>
            <td class="yes">yes</td>
            <td class="no">no</td>
            <td class="no">no</td>
            <td class="no">no</td>
            <td class="no">no</td>
            <td class="partial">partial (Honcho)</td>
            <td class="no">no</td>
          </tr>
          <tr>
            <td>correction chain learning</td>
            <td class="yes">yes</td>
            <td class="no">no</td>
            <td class="no">no</td>
            <td class="no">no</td>
            <td class="no">no</td>
            <td class="no">no</td>
            <td class="no">no</td>
          </tr>
          <tr>
            <td>soul drift scoring</td>
            <td class="yes">0-10 per output</td>
            <td class="no">no</td>
            <td class="no">no</td>
            <td class="no">no</td>
            <td class="no">no</td>
            <td class="no">no</td>
            <td class="no">no</td>
          </tr>
          <tr>
            <td>bias-null filtering</td>
            <td class="yes">5-point filter</td>
            <td class="no">no</td>
            <td class="no">no</td>
            <td class="no">no</td>
            <td class="no">no</td>
            <td class="no">no</td>
          </tr>
          <tr>
            <td>agent handoffs</td>
            <td class="yes">typed + context</td>
            <td class="partial">graph edges</td>
            <td class="partial">manager mode</td>
            <td class="partial">conversation</td>
            <td class="yes">built-in</td>
            <td class="yes">built-in</td>
            <td class="partial">workflow links</td>
          </tr>
          <tr>
            <td>DAG orchestration</td>
            <td class="yes">Seq/Par/Loop</td>
            <td class="yes">core feature</td>
            <td class="partial">basic</td>
            <td class="yes">graph-based</td>
            <td class="yes">Seq/Par/Loop</td>
            <td class="partial">basic</td>
            <td class="yes">visual DAG</td>
          </tr>
          <tr>
            <td>procedural memory</td>
            <td class="yes">FTS5 skill docs</td>
            <td class="no">no</td>
            <td class="no">no</td>
            <td class="no">no</td>
            <td class="partial">memory service</td>
            <td class="yes">70+ skills</td>
            <td class="no">no</td>
          </tr>
          <tr>
            <td>crash recovery / replay</td>
            <td class="yes">deterministic</td>
            <td class="partial">checkpoints</td>
            <td class="no">no</td>
            <td class="no">no</td>
            <td class="partial">session state</td>
            <td class="partial">basic</td>
            <td class="partial">retry only</td>
          </tr>
          <tr>
            <td>observability / tracing</td>
            <td class="partial">trajectory logs</td>
            <td class="yes">LangSmith</td>
            <td class="partial">basic logs</td>
            <td class="partial">basic logs</td>
            <td class="partial">cloud console</td>
            <td class="partial">basic</td>
            <td class="yes">visual UI</td>
          </tr>
          <tr>
            <td>MCP support</td>
            <td class="partial">consume only</td>
            <td class="no">no</td>
            <td class="no">no</td>
            <td class="no">no</td>
            <td class="partial">basic</td>
            <td class="no">no</td>
            <td class="yes">consume + expose</td>
          </tr>
          <tr>
            <td>connector count</td>
            <td>80+ (registry)</td>
            <td>LangChain deps</td>
            <td>tools only</td>
            <td>Azure integrations</td>
            <td>Google Cloud</td>
