<!-- quickstart -->
<section id="quickstart">
  <div class="container">
    <p class="section-label">get started</p>
    <h2 class="section-title">5 commands. running in 2 minutes.</h2>

    <div class="quickstart-block">
      <div class="quickstart-header">terminal</div>
      <pre><span class="cmd">git clone</span> https://github.com/fnsmdehip/sovrun.git
<span class="cmd">cd</span> sovrun && <span class="cmd">pip install</span> -e .

<span class="comment"># build voice model from your prompt history</span>
<span class="cmd">sovrun-voice</span> --extract

<span class="comment"># build correction chains + meta-rules</span>
<span class="cmd">sovrun-engine</span> --build-model

<span class="comment"># close all loops (decisions, feedback, drift scoring)</span>
<span class="cmd">sovrun-loops</span> --cycle

<span class="comment"># see what the system learned about you</span>
<span class="cmd">sovrun-voice</span> --status

<span class="comment"># visualize your agent DAG</span>
<span class="cmd">sovrun-orchestrate</span> --visualize</pre>
    </div>
  </div>
</section>

<!-- architecture -->
<section id="architecture">
  <div class="container">
    <p class="section-label">architecture</p>
    <h2 class="section-title">4 layers. each works standalone.</h2>

    <div class="arch-diagram">
      <pre>
<span class="layer-cognitive">  COGNITIVE                       ORCHESTRATION              MEMORY                INFRASTRUCTURE</span>
<span class="layer-cognitive">  +-----------------------+</span>      <span class="layer-orch">+------------------+</span>      <span class="layer-memory">+------------------+</span>   <span class="layer-infra">+------------------+</span>
<span class="layer-cognitive">  | voice_extractor       |</span>      <span class="layer-orch">| handoff          |</span>      <span class="layer-memory">| procedural_memory|</span>   <span class="layer-infra">| resilience       |</span>
<span class="layer-cognitive">  | cognitive_engine      |</span>  ->  <span class="layer-orch">| orchestration    |</span>  ->  <span class="layer-memory">| conversation_log |</span>   <span class="layer-infra">| durable          |</span>
<span class="layer-cognitive">  | pattern_miner         |</span>      <span class="layer-orch">| loop_closer      |</span>      <span class="layer-memory">| session_briefing |</span>   <span class="layer-infra">|                  |</span>
<span class="layer-cognitive">  | user_sim_refiner      |</span>      <span class="layer-orch">| decision_engine  |</span>      <span class="layer-memory">|                  |</span>   <span class="layer-infra">|                  |</span>
<span class="layer-cognitive">  | self_audit            |</span>      <span class="layer-orch">|                  |</span>      <span class="layer-memory">|                  |</span>   <span class="layer-infra">|                  |</span>
<span class="layer-cognitive">  | bias-null protocol    |</span>      <span class="layer-orch">|                  |</span>      <span class="layer-memory">|                  |</span>   <span class="layer-infra">|                  |</span>
<span class="layer-cognitive">  +-----------------------+</span>      <span class="layer-orch">+------------------+</span>      <span class="layer-memory">+------------------+</span>   <span class="layer-infra">+------------------+</span>

<span style="color: var(--text-dim);">  learns YOUR patterns            composes agent flows        remembers what worked    makes it production-grade
  corrects LLM defaults           closes decision loops       continuity across         retry, circuit break,
  scores drift from intent        typed handoffs              context windows           crash recovery, replay</span>
</pre>
    </div>
  </div>
</section>

<!-- production numbers -->
<section id="numbers">
  <div class="container">
    <p class="section-label">production numbers</p>
    <h2 class="section-title">extracted from a live system. not benchmarks.</h2>
    <p class="section-desc">these numbers are from the production autonomous system sovrun was extracted from. not synthetic tests.</p>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-number">1,510</div>
        <div class="stat-label">prompts analyzed</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">168</div>
        <div class="stat-label">correction chains extracted</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">6.9</div>
        <div class="stat-label">avg corrections per chain</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">0</div>
        <div class="stat-label">external dependencies</div>
      </div>
    </div>
    <p class="stat-note">from the parent system. not a benchmark. your numbers will depend on your prompt history and agent architecture.</p>
  </div>
</section>

