  "content_workflow": {
    "daily_workflow": {
      "morning_block": {
        "duration": "30-45 min",
        "tasks": [
          "Review overnight news",
          "Check RSS feeds and alerts",
          "Post 2-3 recap items",
          "Schedule any evergreen content"
        ]
      },
      "monitoring_block": {
        "duration": "Throughout day",
        "tasks": [
          "Monitor TweetDeck/Hootsuite",
          "Check alerts as they come",
          "React to breaking news within 15 min"
        ]
      },
      "evening_block": {
        "duration": "30-45 min",
        "tasks": [
          "Daily recap post/thread",
          "Schedule next day's evergreen",
          "Engage with comments",
          "Review analytics"
        ]
      }
    },
    "breaking_news_protocol": {
      "step_1": "Verify source (minimum 2 sources for unverified claims)",
      "step_2": "Draft hook and key facts",
      "step_3": "Post within 15 minutes of verification",
      "step_4": "Follow up with context thread if needed",
      "step_5": "Monitor for corrections"
    },
    "verification_checklist": [
      "Is source credible?",
      "Can I find corroboration?",
      "What's the original source?",
      "Are quotes accurate?",
      "Any obvious red flags?"
    ]
  },

