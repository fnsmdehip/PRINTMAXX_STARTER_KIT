  "content_templates": {
    "breaking_news": {
      "format": "BREAKING: [Headline]\n\n- [Key fact 1]\n- [Key fact 2]\n- [Key fact 3]\n\nSource: [publication]"
    },
    "developing_story": {
      "format": "DEVELOPING: [Headline]\n\nWhat we know so far:\n- [Fact 1]\n- [Fact 2]\n\nMore details coming. Follow for updates."
    },
    "context_thread": {
      "format": "1/ [Company/Person] just [action].\n\nHere's why it matters for [audience]:\n\n2/ First, some background:\n[Context]\n\n3/ What actually happened:\n[Details]\n\n4/ Why this matters:\n[Implications]"
    },
    "daily_recap": {
      "format": "[Niche] news you missed today:\n\n1. [Story 1]\n2. [Story 2]\n3. [Story 3]\n4. [Story 4]\n5. [Story 5]\n\nWhich story matters most? Reply below."
    }
  },

