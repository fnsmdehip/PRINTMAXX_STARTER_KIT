  "production_workflow": {
    "research_phase": {
      "time": "30-60 minutes per topic",
      "sources": ["Official documentation", "Academic papers", "Trusted tech publications", "Expert interviews/podcasts"],
      "output": "Simplified outline with key points"
    },
    "script_phase": {
      "time": "30-45 minutes",
      "approach": "Write for 5th grade reading level. Use analogies. Avoid jargon.",
      "tools": ["Hemingway Editor for simplicity check", "Claude for analogy generation"]
    },
    "production_phase": {
      "time": "1-2 hours for short-form, 4-8 hours for long-form",
      "tools": [
        "CapCut/Premiere Pro for editing",
        "Canva for graphics",
        "Screen Studio for screen recordings",
        "Descript for transcription and editing"
      ]
    }
  },

