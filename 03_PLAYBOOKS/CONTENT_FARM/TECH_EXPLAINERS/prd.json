  "content_formats": {
    "tiktok_explainer": {
      "structure": [
        "Hook (0-3 sec): Question or surprising statement",
        "Setup (3-10 sec): Why this matters",
        "Explanation (10-45 sec): Simple breakdown with visuals",
        "Takeaway (45-60 sec): What you should remember/do"
      ],
      "duration": "45-90 seconds",
      "visual_style": "Screen recordings, simple animations, whiteboard-style graphics"
    },
    "carousel_explainer": {
      "structure": [
        "Slide 1: Hook question/statement",
        "Slides 2-8: Step-by-step explanation with visuals",
        "Slide 9: Summary/key points",
        "Slide 10: CTA (follow, save, share)"
      ],
      "design": "Clean, consistent template. High contrast. Large text. Icons over photos."
    },
    "youtube_longform": {
      "structure": [
        "Hook (0-30 sec): What you'll learn",
        "Why it matters (30-60 sec): Real-world impact",
        "Main explanation (2-10 min): Detailed breakdown",
        "Examples (1-2 min): Real applications",
        "Summary (30 sec): Key takeaways",
        "CTA (15 sec): Subscribe, comment, etc."
      ],
      "duration": "5-15 minutes"
    }
  },

