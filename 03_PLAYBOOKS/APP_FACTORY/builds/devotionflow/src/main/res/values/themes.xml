<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
    DailyDevotion Theme Definitions

    Based on Material Design 3 with faith-focused customizations.
    Purple/gold palette for spiritual, calming aesthetic.
    -->

    <!-- Base Application Theme -->
    <style name="Theme.DailyDevotion" parent="Theme.Material3.Light">
        <!-- Primary brand colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>

        <!-- Secondary colors -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_dark</item>
        <item name="colorOnSecondary">@color/text_on_primary</item>

        <!-- Accent/Tertiary -->
        <item name="colorAccent">@color/accent</item>
        <item name="colorTertiary">@color/accent</item>
        <item name="colorOnTertiary">@color/text_on_accent</item>

        <!-- Background colors -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Error colors -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/text_on_primary</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/surface</item>

        <!-- Window -->
        <item name="android:windowBackground">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Default text appearance -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Widget styles -->
        <item name="buttonStyle">@style/Widget.DailyDevotion.Button</item>
        <item name="materialButtonStyle">@style/Widget.DailyDevotion.Button</item>
        <item name="cardViewStyle">@style/Widget.DailyDevotion.CardView</item>
    </style>

    <!-- Dark Theme -->
    <style name="Theme.DailyDevotion.Dark" parent="Theme.Material3.Dark">
        <item name="colorPrimary">@color/primary_light</item>
        <item name="colorPrimaryDark">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary</item>
        <item name="colorOnPrimary">@color/text_primary</item>

        <item name="colorSecondary">@color/secondary_light</item>
        <item name="colorOnSecondary">@color/text_primary</item>

        <item name="colorAccent">@color/accent_light</item>
        <item name="colorTertiary">@color/accent_light</item>

        <item name="android:colorBackground">#121212</item>
        <item name="colorSurface">#1E1E1E</item>
        <item name="colorSurfaceVariant">#2D2D2D</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="colorOnSurfaceVariant">#B0B0B0</item>

        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#121212</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.DailyDevotion.Splash" parent="Theme.DailyDevotion">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">@color/primary</item>
    </style>

    <!-- Button Styles -->
    <style name="Widget.DailyDevotion.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent</item>
        <item name="android:textColor">@color/text_on_accent</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/source_sans_medium</item>
    </style>

    <style name="Widget.DailyDevotion.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.DailyDevotion.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Card Styles -->
    <style name="Widget.DailyDevotion.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/background_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <style name="Widget.DailyDevotion.CardView.Verse" parent="Widget.DailyDevotion.CardView">
        <item name="cardBackgroundColor">@color/primary_light</item>
        <item name="cardCornerRadius">20dp</item>
    </style>

    <!-- Text Styles -->
    <style name="TextAppearance.DailyDevotion.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">@font/lora_regular</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.DailyDevotion.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/source_sans_semibold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.DailyDevotion.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:fontFamily">@font/source_sans_regular</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.DailyDevotion.Verse" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:fontFamily">@font/lora_italic</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:lineSpacingMultiplier">1.4</item>
    </style>

    <style name="TextAppearance.DailyDevotion.VerseReference" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">@font/source_sans_semibold</item>
        <item name="android:textColor">@color/text_on_primary</item>
    </style>

    <style name="TextAppearance.DailyDevotion.Streak" parent="TextAppearance.Material3.DisplaySmall">
        <item name="android:fontFamily">@font/source_sans_bold</item>
        <item name="android:textColor">@color/streak_gold</item>
    </style>

    <style name="TextAppearance.DailyDevotion.HabitName" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:fontFamily">@font/source_sans_medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.DailyDevotion.HabitDescription" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/source_sans_regular</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Checkbox Style -->
    <style name="Widget.DailyDevotion.Checkbox" parent="Widget.Material3.CompoundButton.CheckBox">
        <item name="buttonTint">@color/primary</item>
        <item name="checkedIconTint">@color/success</item>
    </style>

    <!-- Bottom Navigation -->
    <style name="Widget.DailyDevotion.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/surface</item>
        <item name="itemIconTint">@color/primary</item>
        <item name="itemTextColor">@color/primary</item>
        <item name="itemRippleColor">@color/ripple</item>
    </style>

    <!-- FAB Style -->
    <style name="Widget.DailyDevotion.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/accent</item>
        <item name="tint">@color/text_on_accent</item>
    </style>

    <!-- Dialog Theme -->
    <style name="Theme.DailyDevotion.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.DailyDevotion.Dialog</item>
    </style>

    <style name="ShapeAppearance.DailyDevotion.Dialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>
</resources>
