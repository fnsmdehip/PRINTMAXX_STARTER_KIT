# Production Environment Configuration
# Copy to .env.production and fill in your values
# CRITICAL: Never commit this file with real values!

# ==========================================
# App Configuration
# ==========================================

# Production bundle/package identifier
APP_IDENTIFIER=com.yourcompany.app
IOS_APP_IDENTIFIER=com.yourcompany.app
ANDROID_PACKAGE_NAME=com.yourcompany.app

# App Display Name (production)
APP_NAME="App"

# Environment flag
ENVIRONMENT=production

# ==========================================
# API Configuration
# ==========================================

# Production API URL
API_BASE_URL=https://api.yourcompany.com/api

# API timeout in milliseconds
API_TIMEOUT=15000

# Disable debug logging
DEBUG=false
LOG_LEVEL=error

# ==========================================
# Feature Flags
# ==========================================

# Disable all development features
ENABLE_DEV_MENU=false
ENABLE_DEBUG_MODE=false
ENABLE_MOCK_DATA=false
ENABLE_NETWORK_INSPECTOR=false

# Enable all production features
ENABLE_ANALYTICS=true
ENABLE_CRASH_REPORTING=true
ENABLE_RATE_LIMITING=true
ENABLE_SSL_PINNING=true

# Feature rollout flags
ENABLE_NEW_ONBOARDING=true
ENABLE_PREMIUM_FEATURES=true

# ==========================================
# Third-Party Services (Production)
# ==========================================

# RevenueCat (production)
REVENUECAT_API_KEY_IOS=appl_your_production_key_here
REVENUECAT_API_KEY_ANDROID=goog_your_production_key_here
REVENUECAT_SANDBOX=false

# Analytics (production project)
MIXPANEL_TOKEN=your_production_mixpanel_token
AMPLITUDE_API_KEY=your_production_amplitude_key
POSTHOG_API_KEY=your_posthog_key

# Crash Reporting (production)
SENTRY_DSN=https://production@sentry.io/project
CRASHLYTICS_ENABLED=true
BUGSNAG_API_KEY=your_bugsnag_key

# Push Notifications (production)
ONESIGNAL_APP_ID=your_production_onesignal_id

# Customer Support
INTERCOM_APP_ID=your_intercom_app_id
ZENDESK_URL=https://yourcompany.zendesk.com

# ==========================================
# iOS Production
# ==========================================

# Production Team
APPLE_TEAM_ID=XXXXXXXXXX

# App Store code signing
CODE_SIGN_IDENTITY="Apple Distribution"
PROVISIONING_PROFILE_SPECIFIER=match AppStore com.yourcompany.app

# App Store Connect
APP_STORE_CONNECT_API_KEY_ID=XXXXXXXXXX
APP_STORE_CONNECT_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Note: API key .p8 file should be stored securely, not in env

# ==========================================
# Android Production
# ==========================================

# Production keystore (PROTECT THIS!)
ANDROID_KEYSTORE_FILE=production-keystore.jks
ANDROID_KEYSTORE_PASSWORD=your_secure_store_password
ANDROID_KEY_ALIAS=production-key
ANDROID_KEY_PASSWORD=your_secure_key_password

# Build configuration
ANDROID_BUILD_TYPE=release
ANDROID_MIN_SDK=24
ANDROID_TARGET_SDK=34

# Play Store
PLAY_STORE_SERVICE_ACCOUNT_JSON=path/to/service-account.json

# ==========================================
# Security Configuration
# ==========================================

# SSL Pinning
SSL_PINNING_ENABLED=true
SSL_PINS=sha256/XXXXX,sha256/YYYYY

# Certificate Transparency
CERTIFICATE_TRANSPARENCY_ENABLED=true

# Jailbreak/Root Detection
JAILBREAK_DETECTION_ENABLED=true
ROOT_DETECTION_ENABLED=true

# App Attestation
IOS_APP_ATTEST_ENABLED=true
ANDROID_PLAY_INTEGRITY_ENABLED=true

# Database encryption
DATABASE_NAME=app.db
DATABASE_ENCRYPTION_KEY=your_production_encryption_key

# ==========================================
# Monitoring & Alerting
# ==========================================

# Error threshold alerts
ERROR_RATE_THRESHOLD=0.01
CRASH_RATE_THRESHOLD=0.001

# Performance monitoring
PERFORMANCE_MONITORING_ENABLED=true
PERFORMANCE_SAMPLE_RATE=0.1

# Health check endpoint
HEALTH_CHECK_URL=https://api.yourcompany.com/health

# ==========================================
# CI/CD Configuration
# ==========================================

# Match repository for code signing
MATCH_GIT_URL=git@github.com:yourcompany/certificates.git
MATCH_PASSWORD=your_match_password

# Build notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
SLACK_CHANNEL=#releases

# Deployment settings
AUTO_DEPLOY_TO_TESTFLIGHT=false
AUTO_DEPLOY_TO_PLAY_INTERNAL=false
REQUIRE_MANUAL_APPROVAL=true

# ==========================================
# Compliance & Legal
# ==========================================

# Privacy policy URL
PRIVACY_POLICY_URL=https://yourcompany.com/privacy
TERMS_OF_SERVICE_URL=https://yourcompany.com/terms

# GDPR compliance
GDPR_ENABLED=true
DATA_DELETION_ENDPOINT=https://api.yourcompany.com/gdpr/delete

# COPPA compliance (if applicable)
COPPA_ENABLED=false

# ==========================================
# CRITICAL SECURITY NOTES
# ==========================================
#
# 1. NEVER commit this file with real values
# 2. Store secrets in:
#    - GitHub Secrets (for CI/CD)
#    - 1Password or similar (for team access)
#    - AWS Secrets Manager / GCP Secret Manager
#
# 3. Rotate credentials regularly:
#    - API keys: Every 90 days
#    - Signing keys: Keep secure, backup encrypted
#    - Service accounts: Annual review
#
# 4. Production keystore:
#    - Store in multiple secure locations
#    - Never share in plain text
#    - Document recovery procedure
#
# 5. Review access:
#    - Audit who has production credentials
#    - Use least privilege principle
#    - Remove access for departing team members
