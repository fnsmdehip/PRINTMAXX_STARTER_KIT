# Development Environment Configuration
# Copy to .env.development and fill in your values
# Never commit actual .env files with secrets!

# ==========================================
# App Configuration
# ==========================================

# Bundle/Package identifier for development builds
APP_IDENTIFIER=com.yourcompany.app.dev
IOS_APP_IDENTIFIER=com.yourcompany.app.dev
ANDROID_PACKAGE_NAME=com.yourcompany.app.dev

# App Display Name
APP_NAME="App (Dev)"

# Environment flag
ENVIRONMENT=development

# ==========================================
# API Configuration
# ==========================================

# Backend API URL (local development)
API_BASE_URL=http://localhost:3000/api

# API timeout in milliseconds
API_TIMEOUT=30000

# Enable debug logging
DEBUG=true
LOG_LEVEL=debug

# ==========================================
# Feature Flags
# ==========================================

# Enable development-only features
ENABLE_DEV_MENU=true
ENABLE_DEBUG_MODE=true
ENABLE_MOCK_DATA=true
ENABLE_NETWORK_INSPECTOR=true

# Disable production features in dev
ENABLE_ANALYTICS=false
ENABLE_CRASH_REPORTING=false
ENABLE_RATE_LIMITING=false

# ==========================================
# Third-Party Services (Dev/Sandbox)
# ==========================================

# RevenueCat (sandbox)
REVENUECAT_API_KEY_IOS=appl_your_dev_key_here
REVENUECAT_API_KEY_ANDROID=goog_your_dev_key_here

# Analytics (development/debug mode)
MIXPANEL_TOKEN=your_dev_mixpanel_token
AMPLITUDE_API_KEY=your_dev_amplitude_key

# Push Notifications (sandbox)
ONESIGNAL_APP_ID=your_dev_onesignal_id

# ==========================================
# iOS Development
# ==========================================

# Development Team
APPLE_TEAM_ID=XXXXXXXXXX

# Development code signing
CODE_SIGN_IDENTITY="iPhone Developer"
PROVISIONING_PROFILE_SPECIFIER=match Development com.yourcompany.app.dev

# Simulator-first development
IOS_DESTINATION="platform=iOS Simulator,name=iPhone 15"

# ==========================================
# Android Development
# ==========================================

# Debug signing (Android Studio default)
ANDROID_DEBUG_KEYSTORE=~/.android/debug.keystore
ANDROID_DEBUG_KEYSTORE_PASSWORD=android
ANDROID_DEBUG_KEY_ALIAS=androiddebugkey
ANDROID_DEBUG_KEY_PASSWORD=android

# Build configuration
ANDROID_BUILD_TYPE=debug
ANDROID_MIN_SDK=24
ANDROID_TARGET_SDK=34

# ==========================================
# Local Development Tools
# ==========================================

# React Native Debugger
REACT_NATIVE_PACKAGER_HOSTNAME=localhost

# Flipper (Facebook debugging tool)
FLIPPER_ENABLED=true

# Metro bundler
METRO_PORT=8081

# Reactotron
REACTOTRON_HOST=localhost
REACTOTRON_PORT=9090

# ==========================================
# Database (Local)
# ==========================================

# SQLite for local development
DATABASE_NAME=app_dev.db
DATABASE_ENCRYPTION_KEY=dev_encryption_key_change_in_prod

# ==========================================
# Testing
# ==========================================

# Test user credentials (for automated testing)
TEST_USER_EMAIL=dev@test.com
TEST_USER_PASSWORD=test123456

# Skip certain validations in development
SKIP_SSL_VERIFICATION=true
BYPASS_AUTH_FOR_TESTING=true

# ==========================================
# Notes
# ==========================================
#
# 1. Copy this file to .env.development
# 2. Fill in actual values
# 3. Never commit .env files with real values
# 4. Use dotenv or similar to load in your app
#
# For local development:
# - Use iOS Simulator or Android Emulator
# - Run local API server at localhost:3000
# - Enable all debug features
