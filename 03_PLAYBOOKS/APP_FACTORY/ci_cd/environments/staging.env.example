# Staging Environment Configuration
# Copy to .env.staging and fill in your values
# Never commit actual .env files with secrets!

# ==========================================
# App Configuration
# ==========================================

# Bundle/Package identifier for staging builds
APP_IDENTIFIER=com.yourcompany.app.staging
IOS_APP_IDENTIFIER=com.yourcompany.app.staging
ANDROID_PACKAGE_NAME=com.yourcompany.app.staging

# App Display Name
APP_NAME="App (Staging)"

# Environment flag
ENVIRONMENT=staging

# ==========================================
# API Configuration
# ==========================================

# Staging API URL
API_BASE_URL=https://staging-api.yourcompany.com/api

# API timeout in milliseconds
API_TIMEOUT=30000

# Enable verbose logging for debugging
DEBUG=true
LOG_LEVEL=info

# ==========================================
# Feature Flags
# ==========================================

# Enable testing features
ENABLE_DEV_MENU=true
ENABLE_DEBUG_MODE=true
ENABLE_MOCK_DATA=false
ENABLE_NETWORK_INSPECTOR=true

# Enable some production features for testing
ENABLE_ANALYTICS=true
ENABLE_CRASH_REPORTING=true
ENABLE_RATE_LIMITING=false

# Feature flags for A/B testing
ENABLE_NEW_ONBOARDING=true
ENABLE_PREMIUM_FEATURES=true

# ==========================================
# Third-Party Services (Staging)
# ==========================================

# RevenueCat (sandbox mode)
REVENUECAT_API_KEY_IOS=appl_your_staging_key_here
REVENUECAT_API_KEY_ANDROID=goog_your_staging_key_here
REVENUECAT_SANDBOX=true

# Analytics (staging project)
MIXPANEL_TOKEN=your_staging_mixpanel_token
AMPLITUDE_API_KEY=your_staging_amplitude_key

# Crash Reporting (staging project)
SENTRY_DSN=https://staging@sentry.io/project
CRASHLYTICS_ENABLED=true

# Push Notifications (staging)
ONESIGNAL_APP_ID=your_staging_onesignal_id

# ==========================================
# iOS Staging
# ==========================================

# Development/AdHoc Team
APPLE_TEAM_ID=XXXXXXXXXX

# Code signing for TestFlight
CODE_SIGN_IDENTITY="iPhone Distribution"
PROVISIONING_PROFILE_SPECIFIER=match AppStore com.yourcompany.app.staging

# ==========================================
# Android Staging
# ==========================================

# Staging keystore (different from production)
ANDROID_KEYSTORE_FILE=staging-keystore.jks
ANDROID_KEYSTORE_PASSWORD=your_staging_store_password
ANDROID_KEY_ALIAS=staging-key
ANDROID_KEY_PASSWORD=your_staging_key_password

# Build configuration
ANDROID_BUILD_TYPE=release
ANDROID_MIN_SDK=24
ANDROID_TARGET_SDK=34

# ==========================================
# Database
# ==========================================

# Staging database
DATABASE_NAME=app_staging.db
DATABASE_ENCRYPTION_KEY=staging_encryption_key_here

# ==========================================
# Testing Configuration
# ==========================================

# Test users (for QA)
TEST_USER_EMAIL=staging@test.com
TEST_USER_PASSWORD=staging123456

# Staging-specific settings
SKIP_SSL_VERIFICATION=false
BYPASS_AUTH_FOR_TESTING=false

# Internal testing URLs
TESTFLIGHT_FEEDBACK_URL=https://beta.apple.com/sp/betaprogram/
PLAY_STORE_INTERNAL_URL=https://play.google.com/apps/internaltest/

# ==========================================
# CI/CD Configuration
# ==========================================

# Build notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
SLACK_CHANNEL=#staging-builds

# Auto-deploy settings
AUTO_DEPLOY_TO_TESTFLIGHT=true
AUTO_DEPLOY_TO_PLAY_INTERNAL=true

# ==========================================
# Notes
# ==========================================
#
# Staging environment mirrors production but:
# - Uses sandbox payment processing
# - Points to staging API servers
# - Has debug features enabled
# - Distributes via TestFlight / Play Internal
#
# Use for:
# - QA testing before production release
# - Client demos and reviews
# - Integration testing with real devices
# - Performance testing under realistic conditions
